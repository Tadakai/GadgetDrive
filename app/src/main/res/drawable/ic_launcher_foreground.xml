<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer for the adaptive launcher icon (API 26+).
    Draws a USB symbol in white on a transparent background.
    The background colour (#1A6FD6) comes from ic_launcher_background.xml.
    NOTE: VectorDrawable does not support <rect>; rectangles must use <path>.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Vertical stem: M54,22 → M54,84 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:pathData="M54,22 L54,84" />

    <!-- Top horizontal bar -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:pathData="M32,34 L76,34" />

    <!-- Left arm (down from bar) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:pathData="M32,34 L32,54" />

    <!-- Left terminal: filled square (rect replaced with path) -->
    <!-- left=27 top=54 right=37 bottom=64 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M27,54 L37,54 L37,64 L27,64 Z" />

    <!-- Right arm (down from bar) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:pathData="M76,34 L76,48" />

    <!-- Right terminal: filled circle -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M76,48 m-6,0 a6,6 0,1,0 12,0 a6,6 0,1,0 -12,0" />

    <!-- Bottom connector ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:pathData="M54,84 m-8,0 a8,8 0,1,0 16,0 a8,8 0,1,0 -16,0" />

</vector>